<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Círculo decorativo superior derecho -->
    <View
        android:id="@+id/circleTop"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/circle_accent_top"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Círculo decorativo inferior izquierdo -->
    <View
        android:id="@+id/circleBottom"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circle_accent_bottom"
        android:layout_marginBottom="-40dp"
        android:layout_marginStart="-40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:navigationIcon="@drawable/ic_google"
        app:title="Categorías"
        app:titleTextAppearance="@style/TextAppearance.AppCompat.Large"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scroll principal -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="80dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/btnNewCategory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp">

            <!-- Categorías personalizadas -->
            <TextView
                android:id="@+id/tvCustomTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Categorías personalizadas"
                android:fontFamily="@font/playfair_display_bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvCustomSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0 disponibles"
                android:fontFamily="@font/dm_sans"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCustomCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"/>

            <!-- Divisor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:background="@color/divider_color"/>

            <!-- Categorías por defecto -->
            <TextView
                android:id="@+id/tvDefaultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Categorías por defecto"
                android:fontFamily="@font/playfair_display_bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvDefaultSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Editable para usuarios premium"
                android:fontFamily="@font/dm_sans"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDefaultCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"/>

        </LinearLayout>
    </ScrollView>

    <!-- Creamos un botón para añadir una nueva categoría (convive con nav) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNewCategory"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:text="NUEVA CATEGORÍA"
        android:fontFamily="@font/dm_sans_semibold"
        android:textSize="15sp"
        android:textColor="@color/on_accent"
        app:backgroundTint="@color/accent"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:layout_marginBottom="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Navegación inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/card_background"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
